---
import { services } from "../data/site";
---

<section class="services flex items-center py-12" id="services">
  <div class="mx-auto w-full max-w-6xl px-6 py-12 text-white">
    <div class="text-center pb-4">
      <p>{services.label}</p>
      <h2 class="py-2">{services.title}</h2>
      <p class="para-light">{services.text}</p>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" data-aos="zoom-in">
      {services.items.map((item) => (
        <div class="card bg-transparent">
          <i class={item.icon + " fa-2x"}></i>
          <h4 class="py-2">{item.title}</h4>
          <p class="para-light">
            {item.text}
            {item.extraLine && (
              <span>
                <br />
                {item.extraLine}
              </span>
            )}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
