---
import { about } from "../data/site";

const titleWords = about.title.split(" ");
const wordDelayMs = 120;
const textDelayMs = titleWords.length * wordDelayMs + 200;
---

<section class="about flex items-center py-12" id="about">
  <div class="mx-auto w-full max-w-6xl px-6 py-12">
    <div class="grid items-center gap-10 lg:grid-cols-[1.2fr_0.8fr]">
      <div class="about-content">
        <p class="about-label">{about.label}</p>
        <h1 class="about-title">
          {titleWords.map((word, index) => (
            <span class="about-word" style={`--word-delay:${index * wordDelayMs}ms`}>
              {word}
            </span>
          ))}
        </h1>
        <p class="about-text py-2 para-light" style={`--text-delay:${textDelayMs}ms`}>
          {about.text}
        </p>
      </div>
      <div class="text-center" data-aos="fade-down">
        <div class="about-flip" role="img" aria-label={about.imageAlt}>
          <img class="about-face about-face-front" src={about.image} alt={about.imageAlt} />
          <img
            class="about-face about-face-back"
            src="/assets/brand/technized-dark-back.png"
            alt="technized"
          />
        </div>
      </div>
    </div>
  </div>
</section>
